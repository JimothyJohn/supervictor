{
  "name": "supervictor",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "CONTAINER_USER": "esp",
      "CONTAINER_GROUP": "esp",
      "ESP_BOARD": "esp32c3"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",
        "editor.formatOnType": true,
        "lldb.executable": "/usr/bin/lldb",
        "files.watcherExclude": {
          "**/target/**": true
        },
        "rust-analyzer.cargo.allTargets": false,
        "rust-analyzer.cargo.target": "riscv32imc-unknown-none-elf",
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        }
      },
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "fill-labs.dependi",
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        "ms-python.python"
      ]
    }
  },
  // Tell the Docker CLI inside the container to negotiate down to the host daemon's
  // API version rather than assuming its own (newer) default.
  "remoteEnv": {
    "DOCKER_API_VERSION": "${localEnv:DOCKER_API_VERSION:1.43}"
  },
  "forwardPorts": [8000, 3333],
  // Runs on the host before the container starts.
  // Detects the ESP32 serial device and writes ESPFLASH_PORT to .device.env.
  // On macOS, USB pass-through is not supported by Docker Desktop — flash from the host.
  "initializeCommand": ".devcontainer/scripts/detect-device.sh",
  "runArgs": [
    "--privileged",
    "--env-file=.devcontainer/.device.env",
    "--group-add=dialout"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/esp/supervictor,type=bind,consistency=cached",
  "workspaceFolder": "/home/esp/supervictor",
  "mounts": [
    "source=${localEnv:HOME}/.aws,target=/home/esp/.aws,type=bind,consistency=cached,readonly"
  ]
}
